# Shopify Catalog API credentials from Dev Dashboard > Catalogs / app settings.
# Do not commit your real .env file.
SHOPIFY_CATALOG_CLIENT_ID=""
SHOPIFY_CATALOG_CLIENT_SECRET=""

# Optional legacy saved-catalog slug. The skill uses Catalog MCP directly by default,
# so this is only needed if you intentionally compare the legacy GET endpoint.
SHOPIFY_CATALOG_SLUG=""
